{
    "name": "aryeo/api-first",
    "type": "library",
    "repositories": {
        "tooling-laravel": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/tooling-laravel"
        },
        "api-resource-schema": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/api-resource-schema"
        },
        "attribute-routing": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/attribute-routing"
        },
        "eloquent-filters": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/eloquent-filters"
        },
        "entities": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/entities"
        },
        "request-casts": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/request-casts"
        },
        "request-authorizers-validators": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/request-authorizers-validators"
        },
        "primitives": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/primitives"
        }
    },
    "require": {
        "php": "^8.4",
        "aryeo/api-resource-schema": "0.0.13",
        "laravel/framework": "^12.37",
        "laravel/prompts": "^0.3.8",
        "nikic/php-parser": "^5.7",
        "phpstan/phpstan": "^2.1",
        "symfony/console": "^7.4",
        "aryeo/tooling-laravel": "0.0.35",
        "aryeo/attribute-routing": "0.0.12",
        "aryeo/entities": "0.0.15",
        "aryeo/request-casts": "0.0.12",
        "aryeo/request-authorizers-validators": "0.0.10",
        "laravel/passport": "^12.0",
        "symfony/http-foundation": "^7.4"
    },
    "require-dev": {
        "orchestra/testbench": "^10.6",
        "phpunit/phpunit": "^12.4.1",
        "nesbot/carbon": "^3.10",
        "orchestra/testbench-core": "^10.7",
        "pestphp/pest": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Support\\Http\\Api\\": "src/Support/Http/Api",
            "Tooling\\Http\\Api\\": "src/Tooling/Http/Api"
        },
        "exclude-from-classmap": [
            "*Test.php",
            "*TestCases.php",
            "/tests/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Workbench\\App\\": "workbench/app/",
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Justin Seliga",
            "email": "justinsel@zillowgroup.com"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "aryeo/tooling-laravel": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Support\\Http\\Api\\Providers\\Provider"
            ]
        },
        "tooling": {
            "phpstan": "tooling/phpstan/rules.neon"
        }
    }
}
